{
  "appId": "tw.firm-tool",
  "productName": "Firm Tool",
  "copyright": "Copyright © 2026 Accounting Firm",
  "directories": {
    "buildResources": "build",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Firm Tool"
  },
  "extraResources": [
    {
      "from": "data/",
      "to": "data",
      "filter": ["**/*"]
    }
  ],
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*"
  ]
}
